// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("NETLIFY_DATABASE_URL")
  directUrl = env("NETLIFY_DATABASE_URL_UNPOOLED")
}

model Workflow {
  id           String    @id @default(cuid())
  topic        String
  format       String    @default("documentary")
  duration     String    @default("5-10 minutes")
  status       String    @default("in_progress")
  researchData Json?
  storyline    String?
  thumbnailKey String?
  thumbnailUrl String?
  videoUrl     String?
  publishedUrl String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ResearchCache {
  id        String   @id @default(cuid())
  topicHash String   @unique
  topic     String
  data      Json
  createdAt DateTime @default(now())
  expiresAt DateTime
}